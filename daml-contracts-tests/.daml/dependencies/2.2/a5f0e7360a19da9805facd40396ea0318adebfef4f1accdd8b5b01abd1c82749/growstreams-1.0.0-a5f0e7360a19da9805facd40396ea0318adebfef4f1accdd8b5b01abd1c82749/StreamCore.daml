-- daml/StreamCore.daml
-- CC-native streaming with mandatory FeaturedAppActivity recording (CIP-0047)
module StreamCore where

import DA.Time
import FeaturedAppActivity

-- CIP-56 compliant settlement record.
-- symbol = "CC" means Canton Coin.  When splice-amulet.dar is added as a
-- data-dependency, replace CCSettlement with Splice.Amulet.AmuletRules.Transfer.
template CCSettlement
  with
    payer    : Party
    receiver : Party
    amount   : Decimal
    symbol   : Text
    streamId : Int
    reason   : Text
  where
    signatory payer
    observer  receiver
    ensure amount > 0.0 && symbol == "CC"

data StreamStatus = Active | Paused | Stopped
  deriving (Eq, Show)

relTimeToSeconds : RelTime -> Decimal
relTimeToSeconds rt =
  intToDecimal (convertRelTimeToMicroseconds rt) / 1000000.0

calculateAccrued : StreamAgreement -> Time -> Decimal
calculateAccrued stream now =
  if stream.status /= Active then 0.0
  else
    let elapsed   = relTimeToSeconds (subTime now stream.lastUpdate)
        accrued   = stream.flowRate * elapsed
        available = stream.deposited - stream.withdrawn
    in if accrued > available then available else accrued

template StreamAgreement
  with
    streamId   : Int
    sender     : Party
    receiver   : Party
    admin      : Party
    flowRate   : Decimal
    startTime  : Time
    lastUpdate : Time
    deposited  : Decimal
    withdrawn  : Decimal
    status     : StreamStatus
  where
    signatory sender
    observer  receiver, admin

    ensure flowRate > 0.0 && deposited >= 0.0 && withdrawn >= 0.0 && withdrawn <= deposited

    choice Withdraw : (ContractId StreamAgreement, Decimal)
      controller receiver, admin
      do
        now <- getTime
        let withdrawable = calculateAccrued this now
        assertMsg "No tokens to withdraw" (withdrawable > 0.0)
        -- CIP-56 CC settlement record
        _ <- create CCSettlement with
               payer    = sender
               receiver = receiver
               amount   = withdrawable
               symbol   = "CC"
               streamId = streamId
               reason   = "stream_withdraw"
        _ <- create FeaturedAppActivityRecord with
               provider     = admin
               activityType = "stream_withdraw"
               referenceId  = show streamId
               timestamp    = now
        newStream <- create this with
          withdrawn  = withdrawn + withdrawable
          lastUpdate = now
        return (newStream, withdrawable)

    choice TopUp : ContractId StreamAgreement
      with additionalDeposit : Decimal
      controller sender
      do
        assertMsg "Invalid deposit" (additionalDeposit > 0.0)
        create this with deposited = deposited + additionalDeposit

    choice UpdateRate : ContractId StreamAgreement
      with newRate : Decimal
      controller sender, admin
      do
        assertMsg "Invalid rate" (newRate > 0.0)
        assertMsg "Stream must be active" (status == Active)
        now <- getTime
        let accrued = calculateAccrued this now
        if accrued > 0.0
          then do
            _ <- create CCSettlement with
                   payer    = sender
                   receiver = receiver
                   amount   = accrued
                   symbol   = "CC"
                   streamId = streamId
                   reason   = "rate_update_settle"
            _ <- create FeaturedAppActivityRecord with
                   provider     = admin
                   activityType = "rate_update_settle"
                   referenceId  = show streamId
                   timestamp    = now
            return ()
          else return ()
        create this with
          flowRate   = newRate
          withdrawn  = withdrawn + accrued
          lastUpdate = now

    choice Pause : ContractId StreamAgreement
      controller sender, admin
      do
        assertMsg "Already paused or stopped" (status == Active)
        now <- getTime
        let accrued = calculateAccrued this now
        if accrued > 0.0
          then do
            _ <- create CCSettlement with
                   payer    = sender
                   receiver = receiver
                   amount   = accrued
                   symbol   = "CC"
                   streamId = streamId
                   reason   = "pause_settle"
            _ <- create FeaturedAppActivityRecord with
                   provider     = admin
                   activityType = "pause_settle"
                   referenceId  = show streamId
                   timestamp    = now
            return ()
          else return ()
        create this with
          status     = Paused
          withdrawn  = withdrawn + accrued
          lastUpdate = now

    choice Resume : ContractId StreamAgreement
      controller sender
      do
        assertMsg "Not paused" (status == Paused)
        now <- getTime
        create this with
          status     = Active
          lastUpdate = now

    choice Stop : (Decimal, Decimal)
      controller sender, admin
      do
        now <- getTime
        let finalAccrued = calculateAccrued this now
            refundAmount = deposited - withdrawn - finalAccrued
        if finalAccrued > 0.0
          then do
            _ <- create CCSettlement with
                   payer    = sender
                   receiver = receiver
                   amount   = finalAccrued
                   symbol   = "CC"
                   streamId = streamId
                   reason   = "stream_stop_final"
            _ <- create FeaturedAppActivityRecord with
                   provider     = admin
                   activityType = "stream_stop_final"
                   referenceId  = show streamId
                   timestamp    = now
            return ()
          else return ()
        if refundAmount > 0.0
          then do
            _ <- create CCSettlement with
                   payer    = sender
                   receiver = sender
                   amount   = refundAmount
                   symbol   = "CC"
                   streamId = streamId
                   reason   = "stream_stop_refund"
            return ()
          else return ()
        return (finalAccrued, refundAmount)

    nonconsuming choice RecordActivity : ContractId FeaturedAppActivityRecord
      with activityType : Text
      controller admin
      do
        now <- getTime
        create FeaturedAppActivityRecord with
          provider     = admin
          activityType = activityType
          referenceId  = show streamId
          timestamp    = now

    nonconsuming choice ObligationView : Decimal
      controller receiver
      do
        now <- getTime
        return (calculateAccrued this now)

    nonconsuming choice GetWithdrawable : Decimal
      controller receiver
      do
        now <- getTime
        return (calculateAccrued this now)

    nonconsuming choice GetStreamInfo : (Decimal, Decimal, StreamStatus)
      controller sender, receiver
      do
        now <- getTime
        let withdrawable = calculateAccrued this now
        return (withdrawable, withdrawn + withdrawable, status)

template StreamFactory
  with
    admin        : Party
    nextStreamId : Int
    users        : [Party]
  where
    signatory admin
    observer users

    choice CreateStream : (ContractId StreamFactory, ContractId StreamAgreement)
      with
        sender         : Party
        receiver       : Party
        flowRate       : Decimal
        initialDeposit : Decimal
      controller sender
      do
        assertMsg "Sender not in authorized users"   (sender   `elem` users)
        assertMsg "Receiver not in authorized users" (receiver `elem` users)
        assertMsg "Invalid flow rate" (flowRate > 0.0)
        assertMsg "Invalid deposit"   (initialDeposit > 0.0)
        now <- getTime
        _ <- create FeaturedAppActivityRecord with
               provider     = admin
               activityType = "stream_created"
               referenceId  = show nextStreamId
               timestamp    = now
        stream <- create StreamAgreement with
          streamId   = nextStreamId
          sender     = sender
          receiver   = receiver
          admin      = admin
          flowRate   = flowRate
          startTime  = now
          lastUpdate = now
          deposited  = initialDeposit
          withdrawn  = 0.0
          status     = Active
        newFactory <- create this with nextStreamId = nextStreamId + 1
        return (newFactory, stream)

template StreamProposal
  with
    proposalId    : Int
    sender        : Party
    receiver      : Party
    flowRate      : Decimal
    depositAmount : Decimal
    factoryCid    : ContractId StreamFactory
  where
    signatory sender
    observer receiver

    choice AcceptStream : (ContractId StreamFactory, ContractId StreamAgreement)
      controller receiver
      do
        assertMsg "Deposit must be positive" (depositAmount > 0.0)
        assertMsg "Flow rate must be positive" (flowRate > 0.0)
        exercise factoryCid CreateStream with
          sender         = sender
          receiver       = receiver
          flowRate       = flowRate
          initialDeposit = depositAmount

    choice CancelProposal : ()
      controller sender
      do return ()

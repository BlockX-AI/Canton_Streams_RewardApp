module Test.StreamPoolTest where

import Daml.Script
import DA.Date
import DA.Time
import StreamPool
import GrowToken (GrowToken)

testPoolDistribution : Script ()
testPoolDistribution = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob   <- allocateParty "Bob"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd PoolFactory with
      admin      = admin
      nextPoolId = 1

  (_, pool) <- submit admin do
    exerciseCmd factory CreatePool with
      members   = [(alice, 200.0), (bob, 800.0)]
      totalRate = 100.0
      deposit   = 10000.0

  passTime (seconds 100)

  (newPool, aliceToken) <- submit alice do
    exerciseCmd pool WithdrawMember with member = alice

  Some aliceTok <- queryContractId alice aliceToken
  assertMsg "Alice should receive 20% of 100 GROW * 100s = 2000 GROW" (aliceTok.amount == 2000.0)

  passTime (seconds 100)

  (_, bobToken) <- submit bob do
    exerciseCmd newPool WithdrawMember with member = bob

  Some bobTok <- queryContractId bob bobToken
  assertMsg "Bob gets 80% of flow, only for 100s since pool creation" (bobTok.amount == 8000.0)

testPoolIndependentMemberTimers : Script ()
testPoolIndependentMemberTimers = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob   <- allocateParty "Bob"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd PoolFactory with
      admin      = admin
      nextPoolId = 1

  (_, pool) <- submit admin do
    exerciseCmd factory CreatePool with
      members   = [(alice, 500.0), (bob, 500.0)]
      totalRate = 200.0
      deposit   = 50000.0

  passTime (seconds 50)

  (midPool, _) <- submit alice do
    exerciseCmd pool WithdrawMember with member = alice

  passTime (seconds 50)

  (_, aliceToken2) <- submit alice do
    exerciseCmd midPool WithdrawMember with member = alice

  Some aliceTok <- queryContractId alice aliceToken2
  assertMsg "Alice gets 100*50 = 5000 for second 50s window" (aliceTok.amount == 5000.0)

testPoolAddMember : Script ()
testPoolAddMember = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  carol <- allocateParty "Carol"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd PoolFactory with
      admin      = admin
      nextPoolId = 1

  (_, pool) <- submit admin do
    exerciseCmd factory CreatePool with
      members   = [(alice, 1000.0)]
      totalRate = 100.0
      deposit   = 100000.0

  passTime (seconds 100)

  poolWithCarol <- submit admin do
    exerciseCmd pool AddMember with
      newMember = carol
      units     = 1000.0

  passTime (seconds 100)

  (_, carolToken) <- submit carol do
    exerciseCmd poolWithCarol WithdrawMember with member = carol

  Some carolTok <- queryContractId carol carolToken
  assertMsg "Carol only accrues after being added (50% * 100 GROW/s * 100s = 5000)" (carolTok.amount == 5000.0)

testPoolPauseResume : Script ()
testPoolPauseResume = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd PoolFactory with
      admin      = admin
      nextPoolId = 1

  (_, pool) <- submit admin do
    exerciseCmd factory CreatePool with
      members   = [(alice, 1000.0)]
      totalRate = 10.0
      deposit   = 10000.0

  passTime (seconds 100)

  paused <- submit admin do exerciseCmd pool PausePool
  passTime (seconds 100)
  resumed <- submit admin do exerciseCmd paused ResumePool
  passTime (seconds 100)

  (_, token) <- submit alice do
    exerciseCmd resumed WithdrawMember with member = alice

  Some tok <- queryContractId alice token
  assertMsg "Post-resume window: 100s x 10 GROW/s = 1000 GROW" (tok.amount == 1000.0)

  allTokens <- query @GrowToken alice
  let total = foldl (\acc (_, t) -> acc + t.amount) 0.0 allTokens
  assertMsg "Total received (pause + resume) = 2000 GROW" (total == 2000.0)

module Test.StreamCoreTest where

import Daml.Script
import DA.Date
import DA.Time
import StreamCore
import FeaturedAppActivity

testWithdrawCreatesToken : Script ()
testWithdrawCreatesToken = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob   <- allocateParty "Bob"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd StreamFactory with
      admin        = admin
      nextStreamId = 1
      users        = [alice, bob]

  (_, stream) <- submit alice do
    exerciseCmd factory CreateStream with
      sender         = alice
      receiver       = bob
      flowRate       = 1.0
      initialDeposit = 1000.0

  passTime (seconds 100)

  (newStream, amount) <- submitMulti [bob, admin] [] do
    exerciseCmd stream Withdraw

  assertMsg "Should withdraw exactly 100 GROW" (amount == 100.0)

  Some s <- queryContractId bob newStream
  assertMsg "Stream contract must still exist" True
  assertMsg "withdrawn must equal 100" (s.withdrawn == 100.0)

testWithdrawCapsAtDeposit : Script ()
testWithdrawCapsAtDeposit = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob   <- allocateParty "Bob"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd StreamFactory with
      admin        = admin
      nextStreamId = 1
      users        = [alice, bob]

  (_, stream) <- submit alice do
    exerciseCmd factory CreateStream with
      sender         = alice
      receiver       = bob
      flowRate       = 1.0
      initialDeposit = 50.0

  passTime (seconds 200)

  (_, amount) <- submitMulti [bob, admin] [] do
    exerciseCmd stream Withdraw

  assertMsg "Withdrawal capped at 50 GROW deposit" (amount == 50.0)

testPauseResumeCycle : Script ()
testPauseResumeCycle = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob   <- allocateParty "Bob"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd StreamFactory with
      admin        = admin
      nextStreamId = 1
      users        = [alice, bob]

  (_, stream) <- submit alice do
    exerciseCmd factory CreateStream with
      sender         = alice
      receiver       = bob
      flowRate       = 1.0
      initialDeposit = 1000.0

  passTime (seconds 60)

  paused <- submitMulti [alice, admin] [] do
    exerciseCmd stream Pause

  passTime (seconds 60)

  resumed <- submit alice do
    exerciseCmd paused Resume

  passTime (seconds 40)

  (_, amount) <- submitMulti [bob, admin] [] do
    exerciseCmd resumed Withdraw

  assertMsg "Post-resume window: 40s x 1 GROW/s = 40 GROW" (amount == 40.0)

testStopRefundsSender : Script ()
testStopRefundsSender = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob   <- allocateParty "Bob"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd StreamFactory with
      admin        = admin
      nextStreamId = 1
      users        = [alice, bob]

  (_, stream) <- submit alice do
    exerciseCmd factory CreateStream with
      sender         = alice
      receiver       = bob
      flowRate       = 1.0
      initialDeposit = 1000.0

  passTime (seconds 100)

  (finalAccrued, refund) <- submitMulti [alice, admin] [] do
    exerciseCmd stream Stop

  assertMsg "Bob should receive 100 GROW"        (finalAccrued == 100.0)
  assertMsg "Alice should be refunded 900 GROW"  (refund       == 900.0)

testTopUpExtendsStream : Script ()
testTopUpExtendsStream = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob   <- allocateParty "Bob"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd StreamFactory with
      admin        = admin
      nextStreamId = 1
      users        = [alice, bob]

  (_, stream) <- submit alice do
    exerciseCmd factory CreateStream with
      sender         = alice
      receiver       = bob
      flowRate       = 1.0
      initialDeposit = 100.0

  topped <- submit alice do
    exerciseCmd stream TopUp with additionalDeposit = 200.0

  passTime (seconds 300)

  (_, amount) <- submitMulti [bob, admin] [] do
    exerciseCmd topped Withdraw

  assertMsg "Should withdraw full 300 GROW after top-up" (amount == 300.0)

testUnauthorizedWithdrawFails : Script ()
testUnauthorizedWithdrawFails = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob   <- allocateParty "Bob"
  carol <- allocateParty "Carol"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd StreamFactory with
      admin        = admin
      nextStreamId = 1
      users        = [alice, bob]

  (_, stream) <- submit alice do
    exerciseCmd factory CreateStream with
      sender         = alice
      receiver       = bob
      flowRate       = 1.0
      initialDeposit = 1000.0

  passTime (seconds 60)

  submitMustFail carol do
    exerciseCmd stream Withdraw

testFeaturedActivityRecorded : Script ()
testFeaturedActivityRecorded = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob   <- allocateParty "Bob"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd StreamFactory with
      admin        = admin
      nextStreamId = 1
      users        = [alice, bob]

  (_, stream) <- submit alice do
    exerciseCmd factory CreateStream with
      sender         = alice
      receiver       = bob
      flowRate       = 1.0
      initialDeposit = 1000.0

  passTime (seconds 100)

  (_, _) <- submitMulti [bob, admin] [] do
    exerciseCmd stream Withdraw

  activities <- query @FeaturedAppActivityRecord admin
  assertMsg "Withdraw records FeaturedAppActivity" (length activities >= 1)

  let withdrawActivities = filter (\(_, a) -> a.activityType == "stream_withdraw") activities
  assertMsg "Activity type must be stream_withdraw" (length withdrawActivities >= 1)

  let (_, act) = head withdrawActivities
  assertMsg "Provider must be admin" (act.provider == admin)

testPrivacyIsolation : Script ()
testPrivacyIsolation = script do
  admin <- allocateParty "Admin"
  alice <- allocateParty "Alice"
  bob   <- allocateParty "Bob"
  carol <- allocateParty "Carol"

  setTime (time (date 2025 Jan 1) 0 0 0)

  factory <- submit admin do
    createCmd StreamFactory with
      admin        = admin
      nextStreamId = 1
      users        = [alice, bob]

  (_, _stream) <- submit alice do
    exerciseCmd factory CreateStream with
      sender         = alice
      receiver       = bob
      flowRate       = 1.0
      initialDeposit = 500.0

  carolStreams <- query @StreamAgreement carol
  assertMsg "Carol cannot see Alice-Bob stream" (length carolStreams == 0)

  aliceStreams <- query @StreamAgreement alice
  assertMsg "Alice can see the stream she created" (length aliceStreams == 1)

  bobStreams <- query @StreamAgreement bob
  assertMsg "Bob can see the stream he receives" (length bobStreams == 1)

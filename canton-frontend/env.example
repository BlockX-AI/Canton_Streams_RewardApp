# Canton JSON API / Ledger Configuration
CANTON_JSON_API_URL=http://localhost:7575
CANTON_LEDGER_HOST=localhost
CANTON_LEDGER_PORT=6866

# Daml package identifiers (obtained after dpm build / dpm sandbox)
# Run: dpm sandbox --dar .daml/dist/growstreams-1.0.0.dar and inspect the output
CANTON_NAMESPACE=<namespace-fingerprint-from-dpm-sandbox>
CANTON_PACKAGE_ID=<package-id-from-dpm-build>

# Server-side JWT auth secret (must match Canton participant --auth-config)
# Production: use RS256 key pair with a proper OIDC provider instead
CANTON_AUTH_SECRET=change-me-to-a-strong-random-value

# Server-side party IDs (allocated by dpm sandbox or participant node)
# Never expose raw party IDs to the client; use NEXT_PUBLIC_* only for display names
CANTON_ADMIN_PARTY=Admin::<namespace-fingerprint>
CANTON_ALICE_PARTY=Alice::<namespace-fingerprint>
CANTON_BOB_PARTY=Bob::<namespace-fingerprint>

# Legacy NEXT_PUBLIC_ display vars (optional, only for UI labels)
NEXT_PUBLIC_CANTON_JSON_API_URL=http://localhost:7575

# Canton Wallet - Environment Configuration
# Copy this file to .env.local for local development

# Backend API URL (for party generation)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canton Ledger API URL
CANTON_LEDGER_API_URL=http://localhost:7575

# Canton Package ID (DAR)
CANTON_PACKAGE_ID=054d83ae7849878d487d4522881260c5aa599c4c25244040232251cd0c3b5b9c

# Exposed to client — must match CANTON_PACKAGE_ID
NEXT_PUBLIC_CANTON_PACKAGE_ID=054d83ae7849878d487d4522881260c5aa599c4c25244040232251cd0c3b5b9c

# JWT auth secret for DevNet/TestNet validators (HS256)
# Leave empty for sandbox (--allow-insecure-tokens mode)
CANTON_AUTH_SECRET=
